# Copy to .env and fill in your values (never commit .env).

# From @BotFather on Telegram
BOT_TOKEN=

# Your Telegram numeric user ID (send /start to @userinfobot to get it)
USER_ID=

# Optional: Bybit spot pair, e.g. BTCUSDT, ETHUSDT
# SYMBOL=BTCUSDT

# Optional: seconds between polls (default 30)
# POLL_INTERVAL_SEC=30
