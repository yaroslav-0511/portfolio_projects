{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Full Stack",
      "runtimeExecutable": "docker",
      "runtimeArgs": ["compose", "up", "--build"],
      "port": 5432
    },
    {
      "name": "Bot (local)",
      "runtimeExecutable": "python3",
      "runtimeArgs": ["-m", "bot.main"],
      "port": 8080
    },
    {
      "name": "PostgreSQL",
      "runtimeExecutable": "docker",
      "runtimeArgs": ["compose", "up", "db"],
      "port": 5432
    },
    {
      "name": "Redis",
      "runtimeExecutable": "docker",
      "runtimeArgs": ["compose", "up", "redis"],
      "port": 6379
    }
  ]
}
